   "source": [
    "## Section 4: Tax Loss Harvesting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Define tax lots\n",
    "lots_data = [\n",
    "    {'ticker': 'VTI', 'purchase_price': 220, 'quantity': 100,\n",
    "     'purchase_date': '2023-01-15', 'sell_price': None, 'sell_date': None},\n",
    "    {'ticker': 'VTI', 'purchase_price': 210, 'quantity': 50,\n",
    "     'purchase_date': '2023-06-15', 'sell_price': None, 'sell_date': None},\n",
    "    {'ticker': 'VTI', 'purchase_price': 230, 'quantity': 75,\n",
    "     'purchase_date': '2023-09-01', 'sell_price': None, 'sell_date': None},\n",
    "    {'ticker': 'VEA', 'purchase_price': 45, 'quantity': 200,\n",
    "     'purchase_date': '2023-03-01', 'sell_price': None, 'sell_date': None},\n",
    "]\n",
    "\n",
    "lots_df = pd.DataFrame(lots_data)\n",
    "print(\"Current Holdings:\")\n",
    "print(lots_df)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Current market prices\n",
    "current_prices = pd.Series({'VTI': 200, 'VEA': 48})\n",
    "current_date = dt.date.today()\n",
    "\n",
    "print(f\"Current Date: {current_date}\")\n",
    "print(f\"Current Prices:\")\n",
    "for ticker, price in current_prices.items():\n",
    "    print(f\"  {ticker}: ${price}\")\n",
    "\n",
    "# Calculate unrealized gains/losses\n",
    "unrealized = []\n",
    "for _, lot in lots_df.iterrows():\n",
    "    ticker = lot['ticker']\n",
    "    if ticker in current_prices:\n",
    "        current = current_prices[ticker]\n",
    "        cost = lot['purchase_price']\n",
    "        qty = lot['quantity']\n",
    "        gain_loss = (current - cost) * qty\n",
    "        unrealized.append({\n",
    "            'ticker': ticker,\n",
    "            'purchase_date': lot['purchase_date'],\n",
    "            'cost_basis': cost * qty,\n",
    "            'current_value': current * qty,\n",
    "            'gain_loss': gain_loss,\n",
    "            'is_loss': gain_loss < 0\n",
    "        })\n",
    "\n",
    "unrealized_df = pd.DataFrame(unrealized)\n",
    "print(\"\\nUnrealized Gains/Losses:\")\n",
    "print(unrealized_df.round(2))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Identify tax loss harvesting opportunities\n",
    "losses = unrealized_df[unrealized_df['is_loss'] == True]\n",
    "\n",
    "print(\"Tax Loss Harvesting Opportunities:\")\n",
    "if len(losses) > 0:\n",
    "    print(f\"\\nTotal Harvestable Losses: ${losses['gain_loss'].sum():,.2f}\")\n",
    "    print(\"\\nDetails:\")\n",
    "    for _, row in losses.iterrows():\n",
    "        print(f\"  {row['ticker']} ({row['purchase_date']}): "\n",
    "              f\"${abs(row['gain_loss']):,.2f} loss\")\n",
    "    \n",
    "    # ETF replacement options\n",
    "    print(\"\\nReplacement Options:\")\n",
    "    replacements = {\n",
    "        'VTI': ['SCHB', 'ITOT', 'SPY'],\n",
    "        'VEA': ['SCHF', 'VEU', 'IEFA']\n",
    "    }\n",
    "    for _, row in losses.iterrows():\n",
    "        ticker = row['ticker']\n",
    "        if ticker in replacements:\n",
    "            print(f\"  {ticker} → {', '.join(replacements[ticker])}\")\n",
    "else:\n",
    "    print(\"No harvestable losses found.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Tax benefit calculation\n",
    "tax_rate = 0.22  # Short-term capital gains rate\n",
    "harvestable_loss = losses['gain_loss'].sum() if len(losses) > 0 else 0\n",
    "tax_benefit = abs(harvestable_loss) * tax_rate\n",
    "\n",
    "print(\"Tax Benefit Analysis:\")\n",
    "print(f\"  Harvestable Loss: ${abs(harvestable_loss):,.2f}\")\n",
    "print(f\"  Tax Rate: {tax_rate:.0%}\")\n",
    "print(f\"  Tax Benefit: ${tax_benefit:,.2f}\")\n",
    "\n",
    "# Wash sale warning\n",
    "print(\"\\nWash Sale Rule Check:\")\n",
    "recent_purchases = lots_df[lots_df['purchase_date'] > '2023-12-15']  # Within 30 days\n",
    "if len(recent_purchases) > 0:\n",
    "    print(\"  ⚠️  Recent purchases detected:\")\n",
    "    print(recent_purchases[['ticker', 'purchase_date', 'quantity']])\n",
    "    print(\"\\n  Wait 30 days from purchase date to avoid wash sale rule\")\n",
    "else:\n",
    "    print(\"  ✓ No recent purchases - safe to harvest\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 5: Portfolio Backtesting"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Backtesting parameters\n",
    "target_weights = pd.Series([0.6, 0.4], ['VTI', 'AGG'])  # 60/40 portfolio\n",
    "threshold = 0.05  # Rebalance when 5% deviation\n",
    "starting_value = 100000\n",
    "cash_buffer = 0.02  # Keep 2% cash\n",
    "\n",
    "print(\"Backtest Parameters:\")\n",
    "print(f\"  Target Allocation: {target_weights.to_dict()}\")\n",
    "print(f\"  Rebalance Threshold: {threshold:.0%}\")\n",
    "print(f\"  Starting Value: ${starting_value:,}\")\n",
    "print(f\"  Cash Buffer: {cash_buffer:.0%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simple rebalancing backtest\n",
    "def simple_backtest(prices, target_weights, starting_value, threshold=0.05):\n",
    "    \"\"\"Run a simple threshold-based backtest.\"\"\"\n",
    "    portfolio_values = []\n",
    "    holdings = {}\n",
    "    cash = starting_value\n",
    "    \n",
    "    for date in prices.index:\n",
    "        current_prices = prices.loc[date]\n",
    "        \n",
    "        # Mark to market\n",
    "        portfolio_value = cash\n",
    "        for ticker, shares in holdings.items():\n",
    "            if ticker in current_prices:\n",
    "                portfolio_value += shares * current_prices[ticker]\n",
    "        \n",
    "        # Check current weights\n",
    "        current_weights = pd.Series(0.0, index=target_weights.index)\n",
    "        for ticker, shares in holdings.items():\n",
    "            if ticker in current_prices:\n",
    "                current_weights[ticker] = (shares * current_prices[ticker]) / portfolio_value\n",
    "        \n",
    "        # Rebalance if threshold exceeded\n",
    "        if len(holdings) > 0 and (current_weights - target_weights).abs().max() > threshold:\n",
    "            # Sell all and rebuy\n",
    "            for ticker, shares in list(holdings.items()):\n",
    "                cash += shares * current_prices[ticker]\n",
    "            holdings = {}\n",
    "            \n",
    "            investable = portfolio_value * (1 - cash_buffer)\n",
    "            for ticker, weight in target_weights.items():\n",
    "                if ticker in current_prices:\n",
    "                    invest_amount = investable * weight\n",
    "                    shares = invest_amount / current_prices[ticker]\n",
    "                    holdings[ticker] = shares\n",
    "                    cash -= invest_amount\n",
    "        elif len(holdings) == 0:\n",
    "            # Initial purchase\n",
    "            investable = portfolio_value * (1 - cash_buffer)\n",
    "            for ticker, weight in target_weights.items():\n",
    "                if ticker in current_prices:\n",
    "                    invest_amount = investable * weight\n",
    "                    shares = invest_amount / current_prices[ticker]\n",
    "                    holdings[ticker] = shares\n",
    "                    cash -= invest_amount\n",
    "        \n",
    "        portfolio_values.append({'date': date, 'value': portfolio_value})\n",
    "    \n",
    "    return pd.DataFrame(portfolio_values).set_index('date')\n",
    "\n",
    "# Run backtest\n",
    "backtest_results = simple_backtest(\n",
    "    prices[['VTI', 'AGG']], \n",
    "    target_weights, \n",
    "    starting_value,\n",
    "    threshold\n",
    ")\n",
    "\n",
    "print(\"Backtest Complete!\")\n",
    "print(f\"\\nFinal Portfolio Value: ${backtest_results['value'].iloc[-1]:,.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate performance metrics\n",
    "final_value = backtest_results['value'].iloc[-1]\n",
    "total_return = (final_value / starting_value) - 1\n",
    "years = (backtest_results.index[-1] - backtest_results.index[0]).days / 365.25\n",
    "annualized_return = (1 + total_return) ** (1 / years) - 1\n",
    "volatility = backtest_results['value'].pct_change().std() * np.sqrt(252)\n",
    "sharpe_ratio = (annualized_return - 0.02) / volatility if volatility > 0 else 0\n",
    "max_drawdown = ((backtest_results['value'] / backtest_results['value'].cummax()) - 1).min()\n",
    "\n",
    "print(\"Performance Summary:\")\n",
    "print(f\"  Starting Value: ${starting_value:,}\")\n",
    "print(f\"  Final Value: ${final_value:,.2f}\")\n",
    "print(f\"  Total Return: {total_return:.2%}\")\n",
    "print(f\"  Annualized Return: {annualized_return:.2%}\")\n",
    "print(f\"  Volatility: {volatility:.2%}\")\n",
    "print(f\"  Sharpe Ratio: {sharpe_ratio:.2f}\")\n",
    "print(f\"  Max Drawdown: {max_drawdown:.2%}\")"
   ]
