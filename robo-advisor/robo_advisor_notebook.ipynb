    "plt.axhline(y=0, color='k', linestyle='-', linewidth=0.5)\n",
    "plt.legend(loc='upper right')\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "print(\"\\nAllocation Comparison:\")\n",
    "print(allocation_comparison.round(4))"
   ]
  },
