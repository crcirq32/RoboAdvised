   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Robo-Advisor with Python - Interactive Notebook\n",
    "\n",
    "A comprehensive robo-advisor combining:\n",
    "- Mean-Variance Optimization\n",
    "- Hierarchical Risk Parity (HRP)\n",
    "- Tax Loss Harvesting\n",
    "- Portfolio Backtesting\n",
    "- Tax-Efficient Withdrawal Strategies"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Setup and Imports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import datetime as dt\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Try to import optional packages\n",
    "try:\n",
    "    import yfinance as yf\n",
    "    YFINANCE_AVAILABLE = True\n",
    "except ImportError:\n",
    "    YFINANCE_AVAILABLE = False\n",
    "    print(\"Warning: yfinance not installed. Using sample data.\")\n",
    "\n",
    "try:\n",
    "    import cvxpy as cp\n",
    "    CVXPY_AVAILABLE = True\n",
    "except ImportError:\n",
    "    CVXPY_AVAILABLE = False\n",
    "    print(\"Warning: cvxpy not installed. Using analytical solutions.\")\n",
    "\n",
    "try:\n",
    "    from scipy.cluster.hierarchy import linkage, leaves_list\n",
    "    SCIPY_AVAILABLE = True\n",
    "except ImportError:\n",
    "    SCIPY_AVAILABLE = False\n",
    "    print(\"Warning: scipy not installed. HRP may be limited.\")\n",
    "\n",
    "%matplotlib inline"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 1: Data Retrieval"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def get_prices(assets, start_date, end_date):\n",
    "    \"\"\"Retrieve historical prices for given assets.\"\"\"\n",
    "    if YFINANCE_AVAILABLE:\n",
    "        prices = yf.download(assets, start=start_date, end=end_date, progress=False)['Close']\n",
    "        prices.index = pd.Index(map(lambda x: x.date(), prices.index))\n",
    "        if isinstance(prices, pd.Series):\n",
    "            prices = pd.DataFrame(prices)\n",
    "            prices.columns = assets\n",
    "        return prices\n",
    "    else:\n",
    "        # Generate sample data\n",
    "        dates = pd.date_range(start=start_date, end=end_date, freq='B')\n",
    "        prices = pd.DataFrame(index=dates)\n",
    "        np.random.seed(42)\n",
    "        for asset in assets:\n",
    "            returns = np.random.randn(len(dates)) * 0.015 + 0.0003\n",
    "            prices[asset] = 100 * np.exp(np.cumsum(returns))\n",
    "        prices.index = pd.Index(map(lambda x: x.date(), prices.index))\n",
    "        return prices\n",
    "\n",
    "# Example: Download data\n",
    "tickers = ['VTI', 'VEA', 'VWO', 'AGG']\n",
    "prices = get_prices(tickers, '2020-01-01', '2023-12-31')\n",
    "prices.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize price history\n",
    "prices.plot(figsize=(12, 6))\n",
    "plt.title('Historical Prices')\n",
    "plt.ylabel('Price ($)')\n",
    "plt.grid(True)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 2: Mean-Variance Optimization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate returns\n",
    "returns = prices.pct_change().dropna()\n",
    "\n",
    "# Calculate expected returns and covariance\n",
    "expected_returns = returns.mean() * 252  # Annualized\n",
    "cov_matrix = returns.cov() * 252\n",
    "\n",
    "print(\"Expected Returns (Annualized):\")\n",
    "print(expected_returns.round(4))\n",
    "print(\"\\nCovariance Matrix:\")\n",
    "print(cov_matrix.round(4))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Equal-weighted portfolio for comparison\n",
    "equal_weights = pd.Series(1/len(tickers), tickers)\n",
    "print(\"Equal-Weighted Portfolio:\")\n",
    "print(equal_weights.round(4))\n",
    "\n",
    "equal_vol = np.sqrt(equal_weights @ cov_matrix @ equal_weights)\n",
    "equal_ret = equal_weights @ expected_returns\n",
    "print(f\"\\nExpected Return: {equal_ret:.2%}\")\n",
    "print(f\"Volatility: {equal_vol:.2%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Minimum Variance Portfolio\n",
    "if CVXPY_AVAILABLE:\n",
    "    w = cp.Variable(len(tickers))\n",
    "    objective = cp.Minimize(cp.quad_form(w, cov_matrix.values))\n",
    "    constraints = [w >= 0, cp.sum(w) == 1]\n",
    "    prob = cp.Problem(objective, constraints)\n",
    "    prob.solve()\n",
    "    \n",
    "    min_var_weights = pd.Series(w.value, tickers)\n",
    "    print(\"Minimum Variance Portfolio:\")\n",
    "    print(min_var_weights.round(4))\n",
    "    \n",
    "    min_var_vol = np.sqrt(min_var_weights @ cov_matrix @ min_var_weights)\n",
    "    min_var_ret = min_var_weights @ expected_returns\n",
    "    print(f\"\\nExpected Return: {min_var_ret:.2%}\")\n",
    "    print(f\"Volatility: {min_var_vol:.2%}\")\n",
    "else:\n",
    "    print(\"cvxpy not available - showing analytical solution\")\n",
    "    inv_cov = np.linalg.inv(cov_matrix)\n",
    "    min_var_weights = pd.Series(inv_cov.sum(axis=1) / inv_cov.sum(), tickers)\n",
    "    print(min_var_weights.round(4))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Maximum Sharpe Ratio (tangency portfolio)\n",
    "if CVXPY_AVAILABLE:\n",
    "    rf_rate = 0.02  # 2% risk-free rate\n",
    "    excess_returns = expected_returns - rf_rate\n",
    "    \n",
    "    w = cp.Variable(len(tickers))\n",
    "    ret = excess_returns.values @ w\n",
    "    vol = cp.sqrt(cp.quad_form(w, cov_matrix.values))\n",
    "    objective = cp.Maximize(ret / vol)\n",
    "    constraints = [w >= 0, cp.sum(w) == 1]\n",
    "    prob = cp.Problem(objective, constraints)\n",
    "    prob.solve()\n",
    "    \n",
    "    tangency_weights = pd.Series(w.value, tickers)\n",
    "    print(\"Tangency Portfolio (Max Sharpe):\")\n",
    "    print(tangency_weights.round(4))\n",
    "    \n",
    "    tangency_ret = tangency_weights @ expected_returns\n",
    "    tangency_vol = np.sqrt(tangency_weights @ cov_matrix @ tangency_weights)\n",
    "    sharpe = (tangency_ret - rf_rate) / tangency_vol\n",
    "    print(f\"\\nExpected Return: {tangency_ret:.2%}\")\n",
    "    print(f\"Volatility: {tangency_vol:.2%}\")\n",
    "    print(f\"Sharpe Ratio: {sharpe:.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare allocations\n",
    "comparison = pd.DataFrame({\n",
    "    'Equal Weight': equal_weights,\n",
    "    'Min Variance': min_var_weights if CVXPY_AVAILABLE else equal_weights,\n",
    "    'Tangency': tangency_weights if CVXPY_AVAILABLE else equal_weights\n",
    "})\n",
    "\n",
    "ax = comparison.plot(kind='bar', figsize=(10, 6))\n",
    "plt.title('Portfolio Allocations Comparison')\n",
    "plt.ylabel('Weight')\n",
    "plt.axhline(y=0, color='k', linestyle='-', linewidth=0.5)\n",
    "plt.grid(True, alpha=0.3)\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Section 3: Hierarchical Risk Parity"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def calc_distance_matrix(corr):\n",
    "    \"\"\"Transform correlation to distance matrix.\"\"\"\n",
    "    return ((1 - corr) / 2.) ** 0.5\n",
    "\n",
    "def hierarchical_risk_parity(cov, corr):\n",
    "    \"\"\"Calculate HRP portfolio weights.\"\"\"\n",
    "    d = calc_distance_matrix(corr)\n",
    "    tickers = list(d.columns)\n",
    "    \n",
    "    # Calculate linkage matrix\n",
    "    n = d.shape[0]\n",
    "    idx = np.triu_indices(n, k=1)\n",
    "    condensed = d.values[idx]\n",
    "    link_mat = linkage(condensed, method='single')\n",
    "    \n",
    "    # Get ordering\n",
    "    order_indices = leaves_list(link_mat)\n",
    "    ordering = pd.Series([tickers[i] for i in order_indices])\n",
    "    \n",
    "    # Calculate weights recursively\n",
    "    weights = pd.Series(1.0, index=ordering.values)\n",
    "    indices = [pd.RangeIndex(len(ordering))]\n",
    "    \n",
    "    while len(indices) > 0:\n",
    "        # Split indices\n",
    "        splits = []\n",
    "        for i in indices:\n",
    "            if len(i) <= 1:\n",
    "                continue\n",
    "            mid = len(i) // 2\n",
    "            splits.extend([i[:mid], i[mid:]])\n",
    "        indices = splits\n",
    "        \n",
    "        # Calculate variance and allocate\n",
    "        for i in range(0, len(indices), 2):\n",
    "            if i + 1 >= len(indices):\n",
    "                break\n",
    "            i_left, i_right = indices[i], indices[i + 1]\n",
    "            \n",
    "            left_assets = [ordering.values[idx] for idx in i_left]\n",
    "            right_assets = [ordering.values[idx] for idx in i_right]\n",
    "            \n",
    "            # Inverse variance allocation\n",
    "            left_var = (1.0 / np.diag(cov.loc[left_assets, left_assets])).sum()\n",
    "            right_var = (1.0 / np.diag(cov.loc[right_assets, right_assets])).sum()\n",
    "            \n",
    "            if left_var + right_var == 0:\n",
    "                alpha = 0.5\n",
    "            else:\n",
    "                alpha = 1.0 / left_var / (1.0 / left_var + 1.0 / right_var)\n",
    "            \n",
    "            for idx in i_left:\n",
    "                weights.loc[ordering.values[idx]] *= alpha\n",
    "            for idx in i_right:\n",
    "                weights.loc[ordering.values[idx]] *= (1 - alpha)\n",
    "    \n",
    "    # Normalize\n",
    "    weights = weights / weights.sum()\n",
    "    return weights.reindex(tickers)\n",
    "\n",
    "# Calculate HRP weights\n",
    "correlation = returns.corr()\n",
    "hrp_weights = hierarchical_risk_parity(cov_matrix, correlation)\n",
    "\n",
    "print(\"Hierarchical Risk Parity Weights:\")\n",
    "print(hrp_weights.round(4))\n",
    "\n",
    "# Risk characteristics\n",
    "hrp_vol = np.sqrt(hrp_weights @ cov_matrix @ hrp_weights)\n",
    "hrp_ret = hrp_weights @ expected_returns\n",
    "print(f\"\\nExpected Return: {hrp_ret:.2%}\")\n",
    "print(f\"Volatility: {hrp_vol:.2%}\")\n",
    "print(f\"Sharpe Ratio: {(hrp_ret - 0.02) / hrp_vol:.2f}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Visualize correlation matrix\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(8, 6))\n",
    "im = ax.imshow(correlation, cmap='coolwarm', vmin=-1, vmax=1)\n",
    "ax.set_xticks(range(len(tickers)))\n",
    "ax.set_yticks(range(len(tickers)))\n",
    "ax.set_xticklabels(tickers, rotation=45, ha='right')\n",
    "ax.set_yticklabels(tickers)\n",
    "plt.colorbar(im, ax=ax, label='Correlation')\n",
    "plt.title('Asset Correlation Matrix')\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# HRP Dendrogram\n",
    "if SCIPY_AVAILABLE:\n",
    "    from scipy.cluster.hierarchy import dendrogram\n",
    "    fig, ax = plt.subplots(figsize=(10, 6))\n",
    "    d = calc_distance_matrix(correlation)\n",
    "    n = d.shape[0]\n",
    "    idx = np.triu_indices(n, k=1)\n",
    "    condensed = d.values[idx]\n",
    "    link_mat = linkage(condensed, method='single')\n",
    "    dendrogram(link_mat, labels=tickers, ax=ax)\n",
    "    plt.title('Hierarchical Clustering Dendrogram')\n",
    "    plt.ylabel('Distance')\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Compare all three allocation methods\n",
    "allocation_comparison = pd.DataFrame({\n",
    "    'Equal Weight': equal_weights,\n",
    "    'Min Variance': min_var_weights if CVXPY_AVAILABLE else equal_weights,\n",
    "    'Tangency': tangency_weights if CVXPY_AVAILABLE else equal_weights,\n",
    "    'HRP': hrp_weights\n",
    "})\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(12, 6))\n",
