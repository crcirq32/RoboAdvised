    "# Retirement parameters\n",
    "returns = {\n",
    "    'taxable': 0.03,  # After-tax return\n",
    "    'IRA': 0.04,      # Tax-deferred\n",
    "    'Roth': 0.04      # Tax-free\n",
    "}\n",
    "\n",
    "starting_values = {\n",
    "    'taxable': 2000000,\n",
    "    'IRA': 1000000,\n",
    "    'Roth': 0\n",
    "}\n",
    "\n",
    "annual_spending = 120000\n",
    "years = 30\n",
    "\n",
    "print(\"Retirement Scenario:\")\n",
    "print(f\"  Starting Values:\")\n",
    "for acct, val in starting_values.items():\n",
    "    print(f\"    {acct}: ${val:,.0f}\")\n",
    "print(f\"  Annual Spending: ${annual_spending:,.0f}\")\n",
    "print(f\"  Expected Returns:\")\n",
    "for acct, ret in returns.items():\n",
    "    print(f\"    {acct}: {ret:.1%}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Simple withdrawal simulator\n",
    "def simulate_withdrawals(starting_values, returns, annual_spending, \n",
    "                        withdrawal_order, years=30):\n",
    "    \"\"\"Simulate retirement withdrawals.\"\"\"\n",
    "    balances = pd.DataFrame(0.0, columns=['taxable', 'IRA', 'Roth'], \n",
    "                          index=range(years + 1))\n",
    "    balances.iloc[0] = starting_values\n",
    "    \n",
    "    for year in range(years):\n",
    "        if balances.iloc[year].sum() <= annual_spending:\n",
    "            break\n",
    "        \n",
    "        spending_left = annual_spending\n",
    "        balances.iloc[year + 1] = balances.iloc[year]\n",
    "        \n",
    "        for acct_type in withdrawal_order:\n",
    "            if spending_left <= 0:\n",
    "                break\n",
    "            \n",
    "            withdraw = min(balances.iloc[year + 1][acct_type], spending_left)\n",
    "            balances.iloc[year + 1][acct_type] -= withdraw\n",
    "            spending_left -= withdraw\n",
    "        \n",
    "        # Apply returns\n",
    "        for acct_type in ['taxable', 'IRA', 'Roth']:\n",
    "            balances.iloc[year + 1][acct_type] *= (1 + returns[acct_type])\n",
    "    \n",
    "    return balances\n",
    "\n",
    "# Compare different withdrawal strategies\n",
    "strategies = {\n",
    "    'IRA First': ['IRA', 'taxable', 'Roth'],\n",
    "    'Taxable First': ['taxable', 'IRA', 'Roth'],\n",
    "    'Roth First': ['Roth', 'taxable', 'IRA'],\n",
    "}\n",
    "\n",
    "results = {}\n",
    "for name, order in strategies.items():\n",
    "    results[name] = simulate_withdrawals(\n",
    "        starting_values, returns, annual_spending, order, years\n",
    "    )\n",
    "\n",
    "print(\"30-Year Projection (Taxable First Strategy):\")\n",
    "print(results['Taxable First'].head(10).round(0).astype(int))"
   ]
  },
